{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LocalProxyServer": "Information"
    }
  },
  "AllowedHosts": "*",
  "Dns": {
    "Enabled": false,
    "Port": 53,
    "DohEndpoints": [
      "https://dns.google/dns-query",
      "https://cloudflare-dns.com/dns-query"
    ],
    "TimeoutMs": 5000,
    "PreferredAddressFamily": "auto",
    "Cache": {
      "Enabled": true,
      "MaxEntries": 10000,
      "MinTtlSeconds": 30,
      "MaxTtlSeconds": 3600
    },
    "Upstreams": [
      {
        "Enabled": true,
        "Type": "socks5",
        "Host": "localhost",
        "Port": 1081
      }
    ]
  },
  "Proxy": {
    "Port": 8080,
    "UseHttps": true,
    "CrlPort": 8081,
    "LoadBalancingStrategy": "roundRobin",
    "Upstreams": [
      {
        "Enabled": true,
        "Type": "socks5",
        "Host": "localhost",
        "Port": 1081,
        "Process": {
          "AutoStart": false,
          "FileName": "ssh.exe",
          "Arguments": "root@proxy.host -D 1081 -i private.key -N -t",
          "WorkingDirectory": "%OneDrive%\\TOOLS\\SSHKEY",
          "StartupDelayMs": 1000,
          "RedirectOutput": false,
          "AutoRestart": true,
          "MaxRestartAttempts": 1000,
          "RestartDelayMs": 3000
        },
        "HealthCheck": {
          "Enabled": true,
          "IntervalMs": 30000,
          "TimeoutMs": 5000,
          "FailureThreshold": 3
        }
      },
      {
        "Enabled": true,
        "Type": "socks5",
        "Host": "localhost",
        "Port": 1082,
        "Process": {
          "AutoStart": false,
          "FileName": "ssh.exe",
          "Arguments": "--ProxyCommand=\"%LSP_PATH% client tunnel --server %h:%p\" root@proxy.host -D 1082 -i private.key -N -t",
          "WorkingDirectory": "%OneDrive%\\TOOLS\\SSHKEY",
          "StartupDelayMs": 1000,
          "RedirectOutput": false,
          "AutoRestart": true,
          "MaxRestartAttempts": 1000,
          "RestartDelayMs": 3000
        },
        "HealthCheck": {
          "Enabled": false,
          "IntervalMs": 30000,
          "TimeoutMs": 5000,
          "FailureThreshold": 3
        }
      },
      {
        "Enabled": false,
        "Type": "daemon",
        "Host": "localhost",
        "Port": 4430,
        "Process": {
          "AutoStart": true,
          "FileName": "%LSP_PATH%",
          "Arguments": "client tunnel --server proxy.host:4430 --listen 4430",
          "WorkingDirectory": "%LSP_PWD%",
          "StartupDelayMs": 1000,
          "RedirectOutput": true,
          "AutoRestart": true,
          "MaxRestartAttempts": 1000,
          "RestartDelayMs": 3000
        },
        "HealthCheck": {
          "Enabled": false
        }
      },
      {
        "Enabled": false,
        "Type": "socks5",
        "Host": "localhost",
        "Port": 1083,
        "Process": {
          "AutoStart": true,
          "FileName": "ssh.exe",
          "Arguments": "-p 4430 root@127.0.0.1 -D 1083 -i private.key -N -t",
          "WorkingDirectory": "%OneDrive%\\TOOLS\\SSHKEY",
          "StartupDelayMs": 2000,
          "RedirectOutput": false,
          "AutoRestart": true,
          "MaxRestartAttempts": 1000,
          "RestartDelayMs": 3000
        },
        "HealthCheck": {
          "Enabled": true,
          "IntervalMs": 30000,
          "TimeoutMs": 5000,
          "FailureThreshold": 3
        }
      }
    ]
  }
}
